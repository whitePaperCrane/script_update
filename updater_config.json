{
  "startup": {
    "enabled": false,
    "method": "registry_run_key",
    "value_name": "YonghengUpdater",
    "arguments": "--silent"
  },
  "network": {
    "timeout_sec": 25,
    "retries": 5,
    "backoff_sec": 1.6,
    "user_agent": "YonghengUpdater/1.1.1",
    "max_file_bytes": 2147483648
  },
  "jobs": [
    {
      "name": "Bd",
      "kill_processes": [
        "Bd.exe"
      ],
      "start_executable": "Bd.exe",
      "source_url": "http://129.28.62.139:6666/tiantang/Bd/",
      "target_path": "%DESKTOP%/tiantang/Bd",
      "listing": {
        "mode": "autoindex",
        "manifest_url": "",
        "max_depth": 10
      },
      "exclude": [
        "*.log",
        "*.tmp",
        "*.part"
      ],
      "start_on_failure": true
    }
  ]
}
